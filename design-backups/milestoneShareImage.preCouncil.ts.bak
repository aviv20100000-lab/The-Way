function resolveFontFamily(): string {
  const fromVariable = getComputedStyle(document.documentElement)
    .getPropertyValue("--font-rubik")
    .trim();
  return fromVariable ? `${fromVariable}, Rubik, sans-serif` : "Rubik, sans-serif";
}

function font(weight: number, size: number, family: string): string {
  return `${weight} ${size}px ${family}`;
}

function drawSpacedText(
  ctx: CanvasRenderingContext2D,
  text: string,
  centerX: number,
  y: number,
  spacing: number
) {
  const characters = [...text];
  const widths = characters.map((character) => ctx.measureText(character).width);
  const totalWidth = widths.reduce((sum, width) => sum + width, 0) + spacing * (characters.length - 1);
  let x = centerX - totalWidth / 2;

  ctx.textAlign = "left";
  ctx.direction = "ltr";
  characters.forEach((character, index) => {
    ctx.fillText(character, x, y);
    x += widths[index] + spacing;
  });
  ctx.textAlign = "center";
  ctx.direction = "rtl";
}

function measureSpacedText(ctx: CanvasRenderingContext2D, text: string, spacing: number): number {
  const characters = [...text];
  return characters.reduce((sum, character) => sum + ctx.measureText(character).width, 0)
    + spacing * (characters.length - 1);
}

function drawSpacedTextFromLeft(
  ctx: CanvasRenderingContext2D,
  text: string,
  startX: number,
  y: number,
  spacing: number
): number {
  let x = startX;
  ctx.textAlign = "left";
  ctx.direction = "ltr";
  [...text].forEach((character) => {
    ctx.fillText(character, x, y);
    x += ctx.measureText(character).width + spacing;
  });
  return x - spacing;
}

function wrapText(ctx: CanvasRenderingContext2D, text: string, maxWidth: number): string[] {
  const words = text.trim().split(/\s+/);
  const lines: string[] = [];
  let currentLine = "";

  words.forEach((word) => {
    const candidate = currentLine ? `${currentLine} ${word}` : word;
    if (currentLine && ctx.measureText(candidate).width > maxWidth) {
      lines.push(currentLine);
      currentLine = word;
    } else {
      currentLine = candidate;
    }
  });

  if (currentLine) lines.push(currentLine);
  return lines;
}

function getMilestoneType(milestone: MilestoneShareImageInput): MilestoneType {
  return milestone.id?.startsWith("weight-") || milestone.suffix.includes("ק") ? "weight" : "streak";
}

function getProgress(type: MilestoneType, value: number): number {
  const target = type === "weight"
    ? CARD.progress.weightTarget
    : CARD.progress.streakTargets.find((milestone) => milestone > value) ?? value;
  const rawProgress = target === value && type === "streak" ? CARD.progress.maximum : value / target;
  return Math.max(CARD.progress.minimum, Math.min(CARD.progress.maximum, rawProgress));
}

function drawBackground(ctx: CanvasRenderingContext2D) {
  const { width, height } = CARD.canvas;
  const gradient = ctx.createLinearGradient(0, 0, 0, height);
  gradient.addColorStop(0, CARD.colors.backgroundTop);
  gradient.addColorStop(CARD.background.middleStop, CARD.colors.backgroundMiddle);
  gradient.addColorStop(1, CARD.colors.backgroundBottom);
  ctx.fillStyle = gradient;
  ctx.fillRect(0, 0, width, height);

  const glowToken = CARD.background.glow;
  const glow = ctx.createRadialGradient(
    glowToken.x, glowToken.y, glowToken.innerRadius,
    glowToken.x, glowToken.y, glowToken.outerRadius
  );
  glow.addColorStop(0, `rgba(${CARD.colors.limeRgb},${glowToken.alpha})`);
  glow.addColorStop(1, `rgba(${CARD.colors.limeRgb},0)`);
  ctx.fillStyle = glow;
  ctx.fillRect(0, 0, width, height);

  const horizonToken = CARD.background.horizonGlow;
  const horizonGlow = ctx.createRadialGradient(
    horizonToken.x, horizonToken.y, horizonToken.innerRadius,
    horizonToken.x, horizonToken.y, horizonToken.outerRadius
  );
  horizonGlow.addColorStop(0, `rgba(${CARD.colors.limeRgb},${horizonToken.alpha})`);
  horizonGlow.addColorStop(1, `rgba(${CARD.colors.limeRgb},0)`);
  ctx.fillStyle = horizonGlow;
  ctx.fillRect(0, 0, width, height);

  ctx.save();
  ctx.translate(width / 2, height / 2);
  ctx.rotate(CARD.background.stripes.angle);
  ctx.fillStyle = CARD.background.stripes.color;
  CARD.background.stripes.items.forEach((stripe) => {
    ctx.fillRect(stripe.x, stripe.y, stripe.width, stripe.height);
  });
  ctx.restore();

  const beam = CARD.background.beam;
  ctx.beginPath();
  ctx.moveTo(beam.x - beam.topHalfWidth, beam.topY);
  ctx.lineTo(beam.x + beam.topHalfWidth, beam.topY);
  ctx.lineTo(beam.x + beam.bottomHalfWidth, beam.bottomY);
  ctx.lineTo(beam.x - beam.bottomHalfWidth, beam.bottomY);
  ctx.closePath();
  ctx.fillStyle = beam.color;
  ctx.fill();

  const grain = CARD.background.grain;
  for (let index = 0; index < grain.count; index += 1) {
    const isLight = index % grain.alternatingDivisor === 0;
    const alpha = isLight
      ? grain.whiteAlphaMin + Math.random() * grain.whiteAlphaRange
      : grain.blackAlphaMin + Math.random() * grain.blackAlphaRange;
    ctx.fillStyle = isLight
      ? `rgba(${CARD.colors.whiteRgb},${alpha})`
      : `rgba(${CARD.colors.blackRgb},${alpha})`;
    ctx.fillRect(
      Math.random() * width,
      Math.random() * height,
      grain.pixelSize,
      grain.pixelSize
    );
  }

  const vignetteToken = CARD.background.vignette;
  const vignette = ctx.createRadialGradient(
    vignetteToken.x, vignetteToken.y, vignetteToken.innerRadius,
    vignetteToken.x, vignetteToken.y, vignetteToken.outerRadius
  );
  vignette.addColorStop(vignetteToken.clearStop, `rgba(${CARD.colors.blackRgb},0)`);
  vignette.addColorStop(1, `rgba(${CARD.colors.blackRgb},${vignetteToken.edgeAlpha})`);
  ctx.fillStyle = vignette;
  ctx.fillRect(0, 0, width, height);
}

function drawBadge(ctx: CanvasRenderingContext2D, fontFamily: string) {
  const badge = CARD.badge;
  const prefix = "THE W";
  const suffix = "Y";
  ctx.fillStyle = CARD.colors.white;
  ctx.font = font(badge.wordmarkWeight, badge.wordmarkSize, fontFamily);
  const prefixWidth = measureSpacedText(ctx, prefix, badge.wordmarkSpacing);
  const suffixWidth = measureSpacedText(ctx, suffix, badge.wordmarkSpacing);
  const totalWidth = prefixWidth + badge.wordmarkSpacing + badge.customAWidth
    + badge.wordmarkSpacing + suffixWidth;
  const startX = badge.wordmarkX - totalWidth / 2;
  const prefixEndX = drawSpacedTextFromLeft(
    ctx,
    prefix,
    startX,
    badge.wordmarkY,
    badge.wordmarkSpacing
  );
  const customACenterX = prefixEndX + badge.wordmarkSpacing + badge.customAWidth / 2;
  const customABottomY = badge.wordmarkY;
  const customATopY = customABottomY - badge.customAHeight;

  const drawCustomA = () => {
    ctx.beginPath();
    ctx.moveTo(customACenterX - badge.customAWidth / 2, customABottomY);
    ctx.lineTo(customACenterX, customATopY);
    ctx.lineTo(customACenterX + badge.customAWidth / 2, customABottomY);
    ctx.lineCap = "round";
    ctx.lineJoin = "round";
    ctx.stroke();
  };

  ctx.save();
  ctx.strokeStyle = badge.customAGlowColor;
  ctx.lineWidth = badge.customAGlowWidth;
  drawCustomA();
  ctx.strokeStyle = CARD.colors.lime;
  ctx.lineWidth = badge.customAStrokeWidth;
  drawCustomA();
  ctx.beginPath();
  ctx.arc(
    customACenterX,
    customATopY + badge.customADotOffsetY,
    badge.customADotRadius,
    0,
    CARD.ring.fullAngle
  );
  ctx.fillStyle = CARD.colors.white;
  ctx.fill();
  ctx.restore();

  const suffixStartX = customACenterX + badge.customAWidth / 2 + badge.wordmarkSpacing;
  drawSpacedTextFromLeft(ctx, suffix, suffixStartX, badge.wordmarkY, badge.wordmarkSpacing);
  ctx.textAlign = "center";
  ctx.direction = "rtl";
}

function drawProgressRing(ctx: CanvasRenderingContext2D, progress: number) {
  const ring = CARD.ring;
  const endAngle = ring.startAngle + ring.fullAngle * progress;
  const ringGradient = ctx.createLinearGradient(
    ring.x - ring.radius, ring.y, ring.x + ring.radius, ring.y
  );
  ringGradient.addColorStop(0, CARD.colors.lime);
  ringGradient.addColorStop(1, CARD.colors.limeDeep);

  const surfaceGradient = ctx.createRadialGradient(
    ring.surface.highlightX,
    ring.surface.highlightY,
    ring.surface.innerRadius,
    ring.x,
    ring.y,
    ring.surface.outerRadius
  );
  surfaceGradient.addColorStop(0, ring.surface.centerColor);
  surfaceGradient.addColorStop(1, ring.surface.edgeColor);
  ctx.beginPath();
  ctx.arc(ring.x, ring.y, ring.surface.outerRadius, ring.startAngle, ring.startAngle + ring.fullAngle);
  ctx.fillStyle = surfaceGradient;
  ctx.fill();
  ctx.strokeStyle = ring.surface.borderColor;
  ctx.lineWidth = ring.surface.borderWidth;
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(ring.x, ring.y, ring.radius, ring.startAngle, ring.startAngle + ring.fullAngle);
  ctx.strokeStyle = CARD.colors.ring;
  ctx.lineWidth = ring.baseWidth;
  ctx.lineCap = "round";
  ctx.stroke();

  ctx.save();
  ctx.beginPath();
  ctx.arc(ring.x, ring.y, ring.radius, ring.startAngle, endAngle);
  ctx.strokeStyle = ringGradient;
  ctx.lineWidth = ring.progressWidth;
  ctx.shadowColor = ring.glowColor;
  ctx.shadowBlur = ring.glowBlur;
  ctx.stroke();
  ctx.restore();

  ctx.beginPath();
  ctx.arc(ring.x, ring.y, ring.radius, ring.startAngle, endAngle);
  ctx.strokeStyle = ringGradient;
  ctx.lineWidth = ring.progressWidth;
  ctx.stroke();

  const endpointX = ring.x + Math.cos(endAngle) * ring.radius;
  const endpointY = ring.y + Math.sin(endAngle) * ring.radius;
  ctx.save();
  ctx.beginPath();
  ctx.arc(endpointX, endpointY, ring.endpointRadius, 0, ring.fullAngle);
  ctx.fillStyle = CARD.colors.lime;
  ctx.shadowColor = ring.glowColor;
  ctx.shadowBlur = ring.endpointGlowBlur;
  ctx.fill();
  ctx.restore();

}

function drawValue(
  ctx: CanvasRenderingContext2D,
  milestone: MilestoneShareImageInput,
  type: MilestoneType,
  fontFamily: string
) {
  const value = CARD.value;
  const valueText = String(milestone.value);
  const valueSize = valueText.length === 1
    ? value.singleDigitSize
    : valueText.length === 2
      ? value.doubleDigitSize
      : value.tripleDigitSize;
  const valueGradient = ctx.createLinearGradient(
    value.x, value.gradientTopY, value.x, value.gradientBottomY
  );
  valueGradient.addColorStop(0, CARD.colors.white);
  valueGradient.addColorStop(1, CARD.colors.limeSoft);

  if (type === "weight") {
    ctx.direction = "rtl";
    ctx.textAlign = "center";
    ctx.fillStyle = CARD.colors.lime;
    ctx.font = font(value.labelWeight, value.labelSize, fontFamily);
    ctx.fillText(value.weightLabel, value.x, value.labelY);
  }

  ctx.save();
  ctx.direction = "ltr";
  ctx.textAlign = "center";
  ctx.font = font(value.fontWeight, valueSize, fontFamily);
  ctx.fillStyle = valueGradient;
  ctx.shadowColor = value.glowColor;
  ctx.shadowBlur = value.glowBlur;
  ctx.fillText(valueText, value.x, value.baselineY);
  ctx.restore();

  ctx.direction = "rtl";
  ctx.textAlign = "center";
  ctx.font = font(CARD.unit.fontWeight, CARD.unit.fontSize, fontFamily);
  ctx.letterSpacing = `${CARD.unit.letterSpacing}px`;
  ctx.fillStyle = CARD.colors.lime;
  ctx.fillText(milestone.suffix, CARD.unit.x, CARD.unit.baselineY);
  ctx.letterSpacing = "0px";
}

function drawCopy(
  ctx: CanvasRenderingContext2D,
  milestone: MilestoneShareImageInput,
  type: MilestoneType,
  firstName: string | undefined,
  fontFamily: string
) {
  const copy = CARD.copy;
  ctx.direction = "rtl";
  ctx.textAlign = "center";
  ctx.fillStyle = CARD.colors.white;
  ctx.font = font(copy.titleWeight, copy.titleSize, fontFamily);
  const lines = type === "weight" ? [] : wrapText(ctx, milestone.message, copy.titleWidth);
  lines.forEach((line, index) => {
    ctx.fillText(line, copy.x, copy.titleY + index * copy.titleLineHeight);
  });

  if (firstName) {
    ctx.fillStyle = CARD.colors.muted;
    ctx.font = font(copy.firstNameWeight, copy.firstNameSize, fontFamily);
    const firstNameY = type === "weight"
      ? copy.weightFirstNameY
      : copy.titleY + (lines.length - 1) * copy.titleLineHeight + copy.firstNameGap;
    ctx.fillText(`${copy.firstNamePrefix} ${firstName}`, copy.x, firstNameY);
  }
}

function drawBrand(ctx: CanvasRenderingContext2D, fontFamily: string) {
  const brand = CARD.brand;
  ctx.beginPath();
  ctx.moveTo(brand.leftLine.startX, brand.lineY);
  ctx.lineTo(brand.leftLine.endX, brand.lineY);
  ctx.moveTo(brand.rightLine.startX, brand.lineY);
  ctx.lineTo(brand.rightLine.endX, brand.lineY);
  ctx.lineWidth = brand.lineWidth;
  ctx.strokeStyle = CARD.colors.line;
  ctx.stroke();

  ctx.beginPath();
  ctx.arc(brand.x, brand.lineY, brand.centerDotRadius, 0, CARD.ring.fullAngle);
  ctx.fillStyle = CARD.colors.lime;
  ctx.fill();

  ctx.direction = "rtl";
  ctx.textAlign = "center";
  ctx.fillStyle = CARD.colors.subtle;
  ctx.font = font(brand.dateWeight, brand.dateSize, fontFamily);
  const date = new Date().toLocaleDateString("he-IL", {
    day: "numeric",
    month: "long",
    year: "numeric",
  });
  ctx.fillText(date, brand.x, brand.dateY);
}

export async function generateMilestoneShareImage(
  milestone: MilestoneShareImageInput,
  options: MilestoneShareImageOptions = {}
): Promise<Blob> {
  const fontFamily = resolveFontFamily();
  await document.fonts.ready;
  try {
    await Promise.all(CARD.fontLoads.map(({ weight, size, sample }) =>
      document.fonts.load(font(weight, size, fontFamily), sample)
    ));
  } catch {}

  const canvas = document.createElement("canvas");
  canvas.width = CARD.canvas.width;
  canvas.height = CARD.canvas.height;
  const ctx = canvas.getContext("2d");
  if (!ctx) throw new Error("Canvas is not supported in this browser");

  ctx.direction = "rtl";
  ctx.textAlign = "center";
  ctx.textBaseline = "alphabetic";

  const type = getMilestoneType(milestone);
  drawBackground(ctx);
  drawBadge(ctx, fontFamily);
  drawProgressRing(ctx, getProgress(type, milestone.value));
  drawValue(ctx, milestone, type, fontFamily);
  drawCopy(ctx, milestone, type, options.firstName?.trim() || undefined, fontFamily);
  drawBrand(ctx, fontFamily);

  return new Promise<Blob>((resolve, reject) => {
    canvas.toBlob((blob) => {
      if (blob) resolve(blob);
      else reject(new Error("Failed to create milestone image"));
    }, "image/png");
  });
}

